info_file() {
    echo -e "\n${CYAN}[INFO FILE]${NC}"
    read -p "Nama file: " file_info
    if [ -f "$BASE_DIR/$file_info" ]; then
        ffmpeg -i "$BASE_DIR/$file_info" 2>&1 | grep -E "Duration|Video|Audio"
    else
        echo -e "${RED}File tidak ditemukan!${NC}"
    fi
}

