# Warna untuk tampilan
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
CYAN='\033[0;36m'
NC='\033[0m'

# Fungsi header
tampilkan_header() {
    clear
    echo -e "${CYAN}========================================${NC}"
    echo -e "${PURPLE}       JAMIL-YT v$VERSION              ${NC}"
    echo -e "${CYAN}========================================${NC}"
    echo -e "${GREEN}   Media Downloader & Converter Tool    ${NC}"
    echo -e "${CYAN}========================================${NC}\n"
}

# Progress bar persentase untuk FFMPEG
progress_bar_ffmpeg() {
    local duration=$1
    local current=$2
    local width=50
    local percent=$(( current * 100 / duration ))
    local filled=$(( width * current / duration ))
    local empty=$(( width - filled ))
    
    # Warna berdasarkan persentase
    if [ $percent -lt 30 ]; then
        local color=$RED
    elif [ $percent -lt 70 ]; then
        local color=$YELLOW
    else
        local color=$GREEN
    fi
    
    printf "\r${color}["
    printf "%${filled}s" | tr ' ' '█'
    printf "%${empty}s" | tr ' ' '░'
    printf "] ${GREEN}%3d%%${NC} ${CYAN}(${current}/${duration} detik)${NC}" "$percent"
}

# Progress bar dengan spinner
tampilkan_progress() {
    local pid=$1
    local message=$2
    local spin='⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏'
    local i=0
    
    while kill -0 "$pid" 2>/dev/null; do
        printf "\r${CYAN}%s${NC} ${YELLOW}%c${NC}" "$message" "${spin:i++%10:1}"
        sleep 0.1
    done
    wait "$pid" 2>/dev/null
    local exit_code=$?
    if [ $exit_code -eq 0 ]; then
        printf "\r${GREEN}✓ %s Selesai!    ${NC}\n" "$message"
    else
        printf "\r${RED}✗ %s Gagal!    ${NC}\n" "$message"
    fi
    return $exit_code
}

# Fungsi untuk menjalankan FFMPEG dengan progress bar
run_ffmpeg_with_progress() {
    local input_file=$1
    local output_file=$2
    local ffmpeg_args=$3
    
    # Dapatkan durasi total dalam detik
    local total_duration=$(ffprobe -v error -show_entries format=duration -of default=noprint_wrappers=1:nokey=1 "$input_file" 2>/dev/null)
    
    if [ -z "$total_duration" ]; then
        # Jika tidak bisa dapat durasi, jalankan tanpa progress
        eval $ffmpeg_args 2>&1 | tee -a "$LOG_FILE"
        return $?
    fi
    
    # Jalankan ffmpeg dan capture output
    eval $ffmpeg_args 2>&1 | while IFS= read -r line; do
        # Cari timestamp/lama proses
        if [[ $line =~ time=([0-9]+):([0-9]+):([0-9]+)\.([0-9]+) ]]; then
            local hours=${BASH_REMATCH[1]}
            local minutes=${BASH_REMATCH[2]}
            local seconds=${BASH_REMATCH[3]}
            local current_time=$(echo "$hours * 3600 + $minutes * 60 + $seconds" | bc)
            
            # Hitung persentase
            if (( $(echo "$total_duration > 0" | bc -l) )); then
                local percent=$(echo "scale=0; ($current_time * 100) / $total_duration" | bc)
                # Batasi maksimal 99%
                if [ $percent -gt 99 ]; then percent=99; fi
                
                progress_bar_ffmpeg "${total_duration%.*}" "$current_time"
            fi
        fi
        # Log tetap tersimpan
        echo "$line" >> "$LOG_FILE"
    done
    
    echo "" # New line setelah progress selesai
    return 0
}

# Download dengan progress
download_with_progress() {
    local mode=$1
    local url=$2
    
    echo -e "${BLUE}[*] Memulai download...${NC}"
    
    if [ "$mode" = "yt_video" ]; then
        yt-dlp -f "bestvideo[ext=mp4]+bestaudio[ext=m4a]/best[ext=mp4]/best" \
               -o "$BASE_DIR/%(title)s.%(ext)s" \
               --progress \
               "$url" 2>&1 | while IFS= read -r line; do
            if [[ $line =~ ([0-9]+)% ]]; then
                percent=${BASH_REMATCH[1]}
                # Progress bar untuk download
                local width=50
                local filled=$(( width * percent / 100 ))
                local empty=$(( width - filled ))
                printf "\r${GREEN}["
                printf "%${filled}s" | tr ' ' '█'
                printf "%${empty}s" | tr ' ' '░'
                printf "] ${YELLOW}%3d%%${NC}" "$percent"
            fi
        done
        echo -e "\n${GREEN}✓ Download selesai!${NC}"
    elif [ "$mode" = "yt_audio" ]; then
        yt-dlp -f bestaudio \
               --extract-audio \
               --audio-format mp3 \
               --audio-quality 0 \
               -o "$BASE_DIR/%(title)s.%(ext)s" \
               --progress \
               "$url" 2>&1 | while IFS= read -r line; do
            if [[ $line =~ ([0-9]+)% ]]; then
                percent=${BASH_REMATCH[1]}
                local width=50
                local filled=$(( width * percent / 100 ))
                local empty=$(( width - filled ))
                printf "\r${GREEN}["
                printf "%${filled}s" | tr ' ' '█'
                printf "%${empty}s" | tr ' ' '░'
                printf "] ${YELLOW}%3d%%${NC}" "$percent"
            fi
        done
        echo -e "\n${GREEN}✓ Download selesai!${NC}"
    elif [ "$mode" = "ig" ]; then
        yt-dlp -f best \
               -o "$BASE_DIR/instagram_%(id)s.%(ext)s" \
               "$url"
        echo -e "${GREEN}✓ Download Instagram selesai!${NC}"
    fi
}

if [ ! -f "$PY_SCRIPT" ]; then
