cek_file() {
    local file=$1
    if [ ! -f "$BASE_DIR/$file" ]; then
        echo -e "${RED}❌ File '$file' tidak ditemukan di $BASE_DIR${NC}"
        return 1
    fi
    return 0
}

# Fungsi konversi dengan progress
konversi_format() {
    echo -e "\n${CYAN}[KONVERSI FORMAT VIDEO]${NC}"
    echo "Format yang tersedia:"
    echo "  1. MP4 (H.264)"
    echo "  2. AVI"
    echo "  3. MKV"
    echo "  4. MOV"
    echo "  5. WEBM"
    echo "  6. GIF (dari video)"
    echo "  7. MP4 (kualitas rendah - ukuran kecil)"
    echo "  8. MP4 (kualitas tinggi)"
    echo "  9. Extract Frame (JPG per detik)"
    echo "  10. Convert Audio ke MP3"
    
    read -p "Pilih format target (1-10): " format_choice
    read -p "Nama file input: " input_file
    
    cek_file "$input_file" || return 1
    
    local input_path="$BASE_DIR/$input_file"
    local filename="${input_file%.*}"
    local output_file=""
    local ffmpeg_cmd=""
    
    case $format_choice in
        1)
            output_file="${filename}_converted.mp4"
            echo -e "${BLUE}[*] Mengkonversi ke MP4...${NC}"
            ffmpeg_cmd="ffmpeg -i \"$input_path\" -c:v libx264 -preset medium -crf 23 -c:a aac -b:a 128k \"$BASE_DIR/$output_file\" -y"
            ;;
        2)
            output_file="${filename}.avi"
            echo -e "${BLUE}[*] Mengkonversi ke AVI...${NC}"
            ffmpeg_cmd="ffmpeg -i \"$input_path\" -c:v libx264 -c:a mp3 \"$BASE_DIR/$output_file\" -y"
            ;;
        3)
            output_file="${filename}.mkv"
            echo -e "${BLUE}[*] Mengkonversi ke MKV...${NC}"
            ffmpeg_cmd="ffmpeg -i \"$input_path\" -c copy \"$BASE_DIR/$output_file\" -y"
            ;;
        4)
            output_file="${filename}.mov"
            echo -e "${BLUE}[*] Mengkonversi ke MOV...${NC}"
            ffmpeg_cmd="ffmpeg -i \"$input_path\" -c:v libx264 -c:a aac \"$BASE_DIR/$output_file\" -y"
            ;;
        5)
            output_file="${filename}.webm"
            echo -e "${BLUE}[*] Mengkonversi ke WEBM...${NC}"
            ffmpeg_cmd="ffmpeg -i \"$input_path\" -c:v libvpx -c:a libvorbis \"$BASE_DIR/$output_file\" -y"
            ;;
        6)
            output_file="${filename}.gif"
            echo -e "${BLUE}[*] Membuat GIF (10 detik pertama)...${NC}"
            ffmpeg_cmd="ffmpeg -i \"$input_path\" -t 10 -vf \"fps=10,scale=320:-1:flags=lanczos\" -c:v gif \"$BASE_DIR/$output_file\" -y"
            ;;
        7)
            output_file="${filename}_small.mp4"
            echo -e "${BLUE}[*] Mengkompres ke ukuran kecil...${NC}"
            ffmpeg_cmd="ffmpeg -i \"$input_path\" -c:v libx264 -crf 28 -preset fast -c:a aac -b:a 64k -vf \"scale=854:-2\" \"$BASE_DIR/$output_file\" -y"
            ;;
        8)
            output_file="${filename}_high.mp4"
            echo -e "${BLUE}[*] Konversi kualitas tinggi...${NC}"
            ffmpeg_cmd="ffmpeg -i \"$input_path\" -c:v libx264 -preset slow -crf 18 -c:a aac -b:a 320k \"$BASE_DIR/$output_file\" -y"
            ;;
        9)
            output_dir="$BASE_DIR/frames_${filename}"
            mkdir -p "$output_dir"
            echo -e "${BLUE}[*] Ekstrak frame (1 frame per detik)...${NC}"
            ffmpeg -i "$input_path" -vf "fps=1" "$output_dir/frame_%04d.jpg" -y 2>&1 | tee -a "$LOG_FILE"
            echo -e "${GREEN}✓ Frame tersimpan di: $output_dir${NC}"
            return 0
            ;;
        10)
            output_file="${filename}.mp3"
            echo -e "${BLUE}[*] Ekstrak audio ke MP3...${NC}"
            ffmpeg_cmd="ffmpeg -i \"$input_path\" -vn -acodec mp3 -ab 192k \"$BASE_DIR/$output_file\" -y"
            ;;
        *)
            echo -e "${RED}Pilihan tidak valid!${NC}"
            return 1
            ;;
    esac
    
    if [ -n "$ffmpeg_cmd" ]; then
        run_ffmpeg_with_progress "$input_path" "$output_file" "$ffmpeg_cmd"
        if [ $? -eq 0 ] && [ -f "$BASE_DIR/$output_file" ]; then
            echo -e "\n${GREEN}✅ Konversi selesai! File: $BASE_DIR/$output_file${NC}"
            echo -e "${CYAN}Ukuran file: $(du -h "$BASE_DIR/$output_file" | cut -f1)${NC}"
        else
            echo -e "\n${RED}❌ Konversi gagal!${NC}"
        fi
    fi
}

batch_download() {
    local mode=$1
    local url_file="$BASE_DIR/daftar_url.txt"
    
    echo -e "\n${CYAN}[BATCH DOWNLOAD MODE]${NC}"
    echo -e "Buat file daftar URL di: ${YELLOW}$url_file${NC}"
    echo "Format: satu URL per baris"
    echo ""
    
    if [ ! -f "$url_file" ]; then
        read -p "File daftar_url.txt belum ada. Buat sekarang? (y/n): " buat
        if [[ "$buat" =~ ^[Yy]$ ]]; then
            nano "$url_file"
        else
            echo -e "${RED}Batch download dibatalkan.${NC}"
            return 1
        fi
    fi
    
    if [ -f "$url_file" ]; then
        local total=$(grep -c -v "^$" "$url_file")
        echo -e "\n${GREEN}[*] Memulai batch download ($total URL ditemukan)${NC}"
        local counter=1
        
        while IFS= read -r url; do
            [[ -z "$url" ]] && continue
            echo -e "\n${CYAN}[$counter/$total] Mengunduh:${NC} $url"
            
            if [ "$mode" = "video" ]; then
                yt-dlp -f "best[ext=mp4]" -o "$BASE_DIR/%(title)s.%(ext)s" "$url"
            else
                yt-dlp -f bestaudio --extract-audio --audio-format mp3 -o "$BASE_DIR/%(title)s.%(ext)s" "$url"
            fi
            
            echo -e "${GREEN}✓ Selesai download ke-$counter${NC}"
            ((counter++))
        done < "$url_file"
        
        echo -e "\n${GREEN}✅ Batch download selesai!${NC}"
        echo -e "Log disimpan di: ${YELLOW}$LOG_FILE${NC}"
    else
        echo -e "${RED}❌ File daftar_url.txt tidak ditemukan!${NC}"
        return 1
    fi
}

loop_video() {
    local loop_count=$1
    local message=$2
    
    read -p "Nama file input: " vid
    cek_file "$vid" || return 1
    read -p "Nama file output: " out
    
    echo -e "${BLUE}[*] $message${NC}"
    
    local input_path="$BASE_DIR/$vid"
    local output_path="$BASE_DIR/$out"
    
    # Dapatkan durasi asli
    local original_duration=$(ffprobe -v error -show_entries format=duration -of default=noprint_wrappers=1:nokey=1 "$input_path" 2>/dev/null)
    local total_duration=$(echo "$original_duration * $loop_count" | bc)
    
    ffmpeg -stream_loop "$loop_count" -i "$input_path" -c copy "$output_path" -y 2>&1 | while IFS= read -r line; do
        if [[ $line =~ out_time_ms=([0-9]+) ]]; then
            local current_ms=${BASH_REMATCH[1]}
            local current_sec=$(echo "$current_ms / 1000000" | bc)
            if (( $(echo "$total_duration > 0" | bc -l) )); then
                local percent=$(echo "scale=0; ($current_sec * 100) / $total_duration" | bc)
                if [ $percent -gt 99 ]; then percent=99; fi
                progress_bar_ffmpeg "${total_duration%.*}" "$current_sec"
            fi
        fi
    done
    
    echo -e "\n${GREEN}✅ File tersimpan: $output_path${NC}"
}

# ============================================
# PROSES BERANTAI (Dengan Progress Bar)
# ============================================
proses_berantai() {
    echo -e "\n${CYAN}════════════════════════════════════════${NC}"
    echo -e "${PURPLE}     PROSES BERANTAI OTOMATIS${NC}"
    echo -e "${CYAN}════════════════════════════════════════${NC}"
    echo -e "${YELLOW}Proses: Gabung MP3 → Gabung Video → Kompres${NC}"
    echo -e "${CYAN}════════════════════════════════════════${NC}\n"
    
    echo -e "${GREEN}[INPUT FILE MP3]${NC}"
    echo -e "Masukkan nama file MP3 (pisahkan dengan spasi)"
    echo -e "${YELLOW}Contoh: lagu1.mp3 lagu2.mp3 lagu3.mp3${NC}"
    read -p "➜ File MP3: " -a audios
    
    echo ""
    echo -e "${GREEN}[INPUT FILE VIDEO BACKGROUND]${NC}"
    read -p "➜ Nama file video (ex: video.mp4): " video_file
    
    echo ""
    echo -e "${GREEN}[INPUT NAMA FILE OUTPUT]${NC}"
    read -p "➜ Nama file hasil akhir (ex: hasil_akhir.mp4): " final_output
    
    echo ""
    echo -e "${GREEN}[PILIH KOMPRESI]${NC}"
    echo "  1. Ringan (kualitas bagus, ukuran sedang)"
    echo "  2. Sedang (kualitas standar, ukuran kecil)"
    echo "  3. Berat (kualitas rendah, ukuran sangat kecil)"
    echo "  4. WhatsApp (max 16MB)"
    echo "  5. Tanpa kompresi"
    read -p "➜ Pilih (1-5): " compress_level
    
    echo -e "\n${BLUE}────────────────────────────────────────${NC}"
    echo -e "${YELLOW}📋 RINGKASAN INPUT:${NC}"
    echo -e "  MP3 files: ${#audios[@]} file"
    for f in "${audios[@]}"; do
        echo -e "    • $f"
    done
    echo -e "  Video background: $video_file"
    echo -e "  Output akhir: $final_output"
    echo -e "  Kompresi level: $compress_level"
    echo -e "${BLUE}────────────────────────────────────────${NC}"
    
    read -p "Apakah sudah benar? (y/n): " konfirm
    if [[ "$konfirm" != "y" ]]; then
        echo -e "${RED}❌ Dibatalkan!${NC}"
        return 1
    fi
    
    for f in "${audios[@]}"; do
        if [ ! -f "$BASE_DIR/$f" ]; then
            echo -e "${RED}❌ File MP3 '$f' tidak ditemukan!${NC}"
            return 1
        fi
    done
    
    if [ ! -f "$BASE_DIR/$video_file" ]; then
        echo -e "${RED}❌ File video '$video_file' tidak ditemukan!${NC}"
        return 1
    fi
    
    # ========== PROSES 1: GABUNG MP3 ==========
    echo -e "\n${GREEN}[1/3] Menggabungkan ${#audios[@]} file MP3...${NC}"
    
    cd "$BASE_DIR" || return 1
    local merged_mp3="temp_merged_mp3_$$.mp3"
    
    rm -f mp3_list.txt
    for f in "${audios[@]}"; do
        echo "file '$f'" >> mp3_list.txt
    done
    
    # Untuk gabung MP3 tidak bisa pakai progress karena concat cepat
    ffmpeg -f concat -safe 0 -i mp3_list.txt -c copy "$merged_mp3" -y 2>&1 | tee -a "$LOG_FILE" | tail -3
    rm -f mp3_list.txt
    
    if [ ! -f "$merged_mp3" ]; then
        echo -e "${RED}❌ Gagal menggabungkan MP3!${NC}"
        cd "$HOME" || return 1
        return 1
    fi
    
    local mp3_size=$(du -h "$merged_mp3" | cut -f1)
    echo -e "\r${GREEN}✓ MP3 tergabung: $merged_mp3 ($mp3_size)    ${NC}"
    
    # ========== PROSES 2: GABUNG DENGAN VIDEO ==========
    echo -e "\n${GREEN}[2/3] Menggabungkan audio ke video...${NC}"
    
    local mp3_duration=$(ffprobe -v error -show_entries format=duration -of default=noprint_wrappers=1:nokey=1 "$merged_mp3" 2>/dev/null)
    local video_duration=$(ffprobe -v error -show_entries format=duration -of default=noprint_wrappers=1:nokey=1 "$video_file" 2>/dev/null)
    
    echo -e "${CYAN}  Durasi audio MP3: ${mp3_duration} detik${NC}"
    echo -e "${CYAN}  Durasi video: ${video_duration} detik${NC}"
    
    local merged_video="temp_merged_video_$$.mp4"
    
    if (( $(echo "$video_duration < $mp3_duration" | bc -l) )); then
        local loop_needed=$(echo "scale=0; ($mp3_duration / $video_duration) + 1" | bc)
        echo -e "${YELLOW}⚠ Video lebih pendek, di-loop ${loop_needed}x${NC}"
        
        ffmpeg -stream_loop "$loop_needed" -i "$video_file" -i "$merged_mp3" \
            -c:v libx264 -preset fast -crf 23 \
            -c:a aac -b:a 192k \
            -map 0:v -map 1:a \
            -t "$mp3_duration" \
            "$merged_video" -y 2>&1 | while IFS= read -r line; do
                if [[ $line =~ out_time_ms=([0-9]+) ]]; then
                    local current_ms=${BASH_REMATCH[1]}
                    local current_sec=$(echo "$current_ms / 1000000" | bc)
                    if (( $(echo "$mp3_duration > 0" | bc -l) )); then
                        local percent=$(echo "scale=0; ($current_sec * 100) / $mp3_duration" | bc)
                        [ $percent -gt 99 ] && percent=99
                        progress_bar_ffmpeg "${mp3_duration%.*}" "$current_sec"
                    fi
                fi
                echo "$line" >> "$LOG_FILE"
            done
    else
        ffmpeg -i "$video_file" -i "$merged_mp3" \
            -c:v libx264 -preset fast -crf 23 \
            -c:a aac -b:a 192k \
            -map 0:v -map 1:a \
            -t "$mp3_duration" \
            "$merged_video" -y 2>&1 | while IFS= read -r line; do
                if [[ $line =~ out_time_ms=([0-9]+) ]]; then
                    local current_ms=${BASH_REMATCH[1]}
                    local current_sec=$(echo "$current_ms / 1000000" | bc)
                    if (( $(echo "$mp3_duration > 0" | bc -l) )); then
                        local percent=$(echo "scale=0; ($current_sec * 100) / $mp3_duration" | bc)
                        [ $percent -gt 99 ] && percent=99
                        progress_bar_ffmpeg "${mp3_duration%.*}" "$current_sec"
                    fi
                fi
                echo "$line" >> "$LOG_FILE"
            done
    fi
    
    if [ ! -f "$merged_video" ]; then
        echo -e "\n${RED}❌ Gagal menggabungkan video!${NC}"
        rm -f "$merged_mp3"
        cd "$HOME" || return 1
        return 1
    fi
    
    local video_size=$(du -h "$merged_video" | cut -f1)
    echo -e "\n${GREEN}✓ Video tergabung: $merged_video ($video_size)${NC}"
    
    # ========== PROSES 3: KOMPRESI ==========
    echo -e "\n${GREEN}[3/3] Mengkompres video...${NC}"
    
    local compress_cmd=""
    case $compress_level in
        1)
            echo -e "${BLUE}→ Kompres ringan (CRF 23)${NC}"
            compress_cmd="ffmpeg -i \"$merged_video\" -c:v libx264 -crf 23 -preset medium -c:a aac -b:a 128k \"$final_output\" -y"
            ;;
        2)
            echo -e "${BLUE}→ Kompres sedang (CRF 28)${NC}"
            compress_cmd="ffmpeg -i \"$merged_video\" -c:v libx264 -crf 28 -preset fast -c:a aac -b:a 96k \"$final_output\" -y"
            ;;
        3)
            echo -e "${BLUE}→ Kompres berat (CRF 32)${NC}"
            compress_cmd="ffmpeg -i \"$merged_video\" -c:v libx264 -crf 32 -preset veryfast -vf scale=854:-2 -c:a aac -b:a 64k \"$final_output\" -y"
            ;;
        4)
            echo -e "${BLUE}→ Kompres WhatsApp (max 16MB)${NC}"
            compress_cmd="ffmpeg -i \"$merged_video\" -c:v libx264 -crf 28 -preset fast -vf scale=1280:-2 -c:a aac -b:a 96k -fs 16M \"$final_output\" -y"
            ;;
        5)
            echo -e "${BLUE}→ Tanpa kompresi${NC}"
            cp "$merged_video" "$final_output"
            ;;
        *)
            echo -e "${RED}Pilihan tidak valid! Kompres sedang${NC}"
            compress_cmd="ffmpeg -i \"$merged_video\" -c:v libx264 -crf 28 -preset fast -c:a aac -b:a 96k \"$final_output\" -y"
            ;;
    esac
    
    if [ -n "$compress_cmd" ]; then
        local compress_duration=$(ffprobe -v error -show_entries format=duration -of default=noprint_wrappers=1:nokey=1 "$merged_video" 2>/dev/null)
        
        eval $compress_cmd 2>&1 | while IFS= read -r line; do
            if [[ $line =~ out_time_ms=([0-9]+) ]]; then
                local current_ms=${BASH_REMATCH[1]}
                local current_sec=$(echo "$current_ms / 1000000" | bc)
                if (( $(echo "$compress_duration > 0" | bc -l) )); then
                    local percent=$(echo "scale=0; ($current_sec * 100) / $compress_duration" | bc)
                    [ $percent -gt 99 ] && percent=99
                    progress_bar_ffmpeg "${compress_duration%.*}" "$current_sec"
                fi
            fi
            echo "$line" >> "$LOG_FILE"
        done
    fi
    
    if [ -f "$final_output" ]; then
        local final_size=$(du -h "$final_output" | cut -f1)
        local final_duration=$(ffprobe -v error -show_entries format=duration -of default=noprint_wrappers=1:nokey=1 "$final_output" 2>/dev/null)
        
        echo -e "\n\n${GREEN}════════════════════════════════════════${NC}"
        echo -e "${GREEN}✅ PROSES BERANTAI SELESAI!${NC}"
        echo -e "${GREEN}════════════════════════════════════════${NC}"
        echo -e "${CYAN}📁 File hasil: $BASE_DIR/$final_output${NC}"
        echo -e "${CYAN}📊 Ukuran akhir: $final_size${NC}"
        echo -e "${CYAN}⏱ Durasi akhir: ${final_duration%.*} detik${NC}"
        echo -e "\n${YELLOW}📋 RINGKASAN:${NC}"
        echo -e "  • ${#audios[@]} MP3 digabung → $mp3_size"
        echo -e "  • + Video background → $video_size"
        echo -e "  • Hasil kompresi → $final_size"
        
        rm -f "$merged_mp3" "$merged_video"
        
        echo ""
        read -p "Buka folder penyimpanan? (y/n): " buka_folder
        if [[ "$buka_folder" =~ ^[Yy]$ ]]; then
            termux-open "$BASE_DIR"
        fi
    else
        echo -e "\n${RED}❌ Proses gagal!${NC}"
        rm -f "$merged_mp3" "$merged_video"
    fi
    
    cd "$HOME" || return 1
}

