# Konfigurasi
BASE_DIR="/storage/emulated/0/JAMIL-YT"
PY_SCRIPT="$PREFIX/bin/jamil_downloader.py"
LOG_FILE="$BASE_DIR/jamil_log.txt"
VERSION="3.0"

# Buat folder jika belum ada
mkdir -p "$BASE_DIR"
touch "$LOG_FILE"

# Warna untuk tampilan
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
CYAN='\033[0;36m'
NC='\033[0m'

# ============================================
# FUNGSI DASAR
# ============================================

tampilkan_header() {
    clear
    echo -e "${CYAN}========================================${NC}"
    echo -e "${PURPLE}       JAMIL-YT v$VERSION              ${NC}"
    echo -e "${CYAN}========================================${NC}"
    echo -e "${GREEN}   Media Downloader & Converter Tool    ${NC}"
    echo -e "${CYAN}========================================${NC}\n"
}

progress_bar_download() {
    local percent=$1
    local width=40
    local filled=$(( width * percent / 100 ))
    local empty=$(( width - filled ))
    
    printf "\r${GREEN}["
    printf "%${filled}s" | tr ' ' '█'
    printf "%${empty}s" | tr ' ' '░'
    printf "] ${YELLOW}%3d%%${NC}" "$percent"
}

spinner_loading() {
    local pid=$1
    local message=$2
    local spin='⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏'
    local i=0
    
    while kill -0 "$pid" 2>/dev/null; do
        printf "\r${CYAN}%s${NC} ${YELLOW}%c${NC}" "$message" "${spin:i++%10:1}"
        sleep 0.15
    done
    wait "$pid" 2>/dev/null
    local exit_code=$?
    if [ $exit_code -eq 0 ]; then
        printf "\r${GREEN}✓ %s Selesai!    ${NC}\n" "$message"
    else
        printf "\r${RED}✗ %s Gagal!    ${NC}\n" "$message"
    fi
    return $exit_code
}

exec_with_spinner() {
    local cmd="$1"
    local message="$2"
    
    echo -e "${BLUE}[*] ${message}...${NC}"
    eval "$cmd" &
    local pid=$!
    spinner_loading "$pid" "$message"
    return $?
}

kembali_ke_menu() {
    echo -e "\n${CYAN}----------------------------------------${NC}"
    read -p "Tekan [Enter] untuk kembali ke menu utama..."
}

konfirmasi_menu() {
    echo -e "\n${YELLOW}[Tekan 'n' lalu Enter jika ingin batal]${NC}"
    read -p "Apakah ingin melanjutkan? (y/n): " konfirm
    [[ "$konfirm" =~ ^[Nn]$ ]] && return 1 || return 0
}

cek_file() {
    local file=$1
    if [ ! -f "$BASE_DIR/$file" ]; then
        echo -e "${RED}❌ File '$file' tidak ditemukan di $BASE_DIR${NC}"
        return 1
    fi
    return 0
}

# ============================================
# DOWNLOADER
# ============================================

download_with_progress() {
    local mode=$1
    local url=$2
    
    echo -e "${BLUE}[*] Memulai download...${NC}"
    
    if [ "$mode" = "yt_video" ]; then
        yt-dlp -f "bestvideo[ext=mp4]+bestaudio[ext=m4a]/best[ext=mp4]/best" \
               -o "$BASE_DIR/%(title)s.%(ext)s" \
               --progress \
               "$url" 2>&1 | while IFS= read -r line; do
            if [[ $line =~ ([0-9]+)% ]]; then
                progress_bar_download "${BASH_REMATCH[1]}"
            fi
        done
        echo -e "\n${GREEN}✓ Download selesai!${NC}"
    elif [ "$mode" = "yt_audio" ]; then
        yt-dlp -f bestaudio \
               --extract-audio \
               --audio-format mp3 \
               --audio-quality 0 \
               -o "$BASE_DIR/%(title)s.%(ext)s" \
               --progress \
               "$url" 2>&1 | while IFS= read -r line; do
            if [[ $line =~ ([0-9]+)% ]]; then
                progress_bar_download "${BASH_REMATCH[1]}"
            fi
        done
        echo -e "\n${GREEN}✓ Download selesai!${NC}"
    elif [ "$mode" = "ig" ]; then
        yt-dlp -f best -o "$BASE_DIR/instagram_%(id)s.%(ext)s" "$url"
        echo -e "${GREEN}✓ Download Instagram selesai!${NC}"
    fi
}

download_playlist() {
    echo -e "\n${CYAN}[DOWNLOAD PLAYLIST]${NC}"
    read -p "URL Playlist YouTube: " playlist_url
    
    echo -e "\n${GREEN}[PILIH FORMAT]${NC}"
    echo "  1. Video (MP4)"
    echo "  2. Audio (MP3)"
    read -p "Pilih (1-2): " format_choice
    
    echo -e "\n${GREEN}[RENTANG VIDEO]${NC}"
    echo "  1. Semua video"
    echo "  2. Rentang tertentu (misal: 1-10)"
    echo "  3. Video tertentu (misal: 1,3,5,7)"
    read -p "Pilih (1-3): " range_choice
    
    local yt_opts=""
    
    case $range_choice in
        2) 
            read -p "Rentang (contoh: 1-10): " range
            yt_opts="--playlist-start ${range%-*} --playlist-end ${range#*-}"
            ;;
        3) 
            read -p "Nomor video (contoh: 1,3,5,7): " numbers
            yt_opts="--playlist-items $numbers"
            ;;
    esac
    
    if [ "$format_choice" = "1" ]; then
        exec_with_spinner "yt-dlp $yt_opts -f 'best[ext=mp4]' -o '$BASE_DIR/%(playlist)s/%(playlist_index)s - %(title)s.%(ext)s' '$playlist_url'" "Download playlist video"
    else
        exec_with_spinner "yt-dlp $yt_opts -x --audio-format mp3 -o '$BASE_DIR/%(playlist)s/%(title)s.%(ext)s' '$playlist_url'" "Download playlist audio"
    fi
    
    echo -e "${GREEN}✅ Playlist selesai didownload!${NC}"
}

batch_download() {
    local mode=$1
    local url_file="$BASE_DIR/daftar_url.txt"
    
    echo -e "\n${CYAN}[BATCH DOWNLOAD]${NC}"
    echo -e "File daftar URL: ${YELLOW}$url_file${NC}"
    
    if [ ! -f "$url_file" ]; then
        read -p "Buat file sekarang? (y/n): " buat
        [[ "$buat" =~ ^[Yy]$ ]] && nano "$url_file" || return 1
    fi
    
    if [ -f "$url_file" ]; then
        local total=$(grep -c -v "^$" "$url_file")
        echo -e "${GREEN}[*] Memulai batch ($total URL)${NC}"
        local counter=1
        
        while IFS= read -r url; do
            [[ -z "$url" ]] && continue
            echo -e "\n${CYAN}[$counter/$total]${NC} $url"
            
            if [ "$mode" = "video" ]; then
                exec_with_spinner "yt-dlp -f 'best[ext=mp4]' -o '$BASE_DIR/%(title)s.%(ext)s' '$url'" "Download video"
            else
                exec_with_spinner "yt-dlp -x --audio-format mp3 -o '$BASE_DIR/%(title)s.%(ext)s' '$url'" "Download audio"
            fi
            ((counter++))
        done < "$url_file"
        
        echo -e "\n${GREEN}✅ Batch selesai!${NC}"
    fi
}

# ============================================
# KONVERSI & EDITING
# ============================================

konversi_format() {
    echo -e "\n${CYAN}[KONVERSI FORMAT VIDEO]${NC}"
    echo "Format yang tersedia:"
    echo "  1. MP4 (H.264)"
    echo "  2. AVI"
    echo "  3. MKV"
    echo "  4. MOV"
    echo "  5. WEBM"
    echo "  6. GIF (dari video)"
    echo "  7. MP4 (kualitas rendah)"
    echo "  8. MP4 (kualitas tinggi)"
    echo "  9. Extract Frame (JPG)"
    echo "  10. Convert Audio ke MP3"
    
    read -p "Pilih (1-10): " format_choice
    read -p "Nama file input: " input_file
    
    cek_file "$input_file" || return 1
    
    local input_path="$BASE_DIR/$input_file"
    local filename="${input_file%.*}"
    local output_file=""
    local cmd=""
    
    case $format_choice in
        1) output_file="${filename}_converted.mp4"
           cmd="ffmpeg -i \"$input_path\" -c:v libx264 -preset medium -crf 23 -c:a aac -b:a 128k \"$BASE_DIR/$output_file\" -y"
           ;;
        2) output_file="${filename}.avi"
           cmd="ffmpeg -i \"$input_path\" -c:v libx264 -c:a mp3 \"$BASE_DIR/$output_file\" -y"
           ;;
        3) output_file="${filename}.mkv"
           cmd="ffmpeg -i \"$input_path\" -c copy \"$BASE_DIR/$output_file\" -y"
           ;;
        4) output_file="${filename}.mov"
           cmd="ffmpeg -i \"$input_path\" -c:v libx264 -c:a aac \"$BASE_DIR/$output_file\" -y"
           ;;
        5) output_file="${filename}.webm"
           cmd="ffmpeg -i \"$input_path\" -c:v libvpx -c:a libvorbis \"$BASE_DIR/$output_file\" -y"
           ;;
        6) output_file="${filename}.gif"
           cmd="ffmpeg -i \"$input_path\" -t 10 -vf \"fps=10,scale=320:-1:flags=lanczos\" -c:v gif \"$BASE_DIR/$output_file\" -y"
           ;;
        7) output_file="${filename}_small.mp4"
           cmd="ffmpeg -i \"$input_path\" -c:v libx264 -crf 28 -preset fast -c:a aac -b:a 64k -vf \"scale=854:-2\" \"$BASE_DIR/$output_file\" -y"
           ;;
        8) output_file="${filename}_high.mp4"
           cmd="ffmpeg -i \"$input_path\" -c:v libx264 -preset slow -crf 18 -c:a aac -b:a 320k \"$BASE_DIR/$output_file\" -y"
           ;;
        9) output_dir="$BASE_DIR/frames_${filename}"
           mkdir -p "$output_dir"
           exec_with_spinner "ffmpeg -i \"$input_path\" -vf \"fps=1\" \"$output_dir/frame_%04d.jpg\" -y" "Ekstrak frame"
           echo -e "${GREEN}✓ Frame tersimpan di: $output_dir${NC}"
           return 0
           ;;
        10) output_file="${filename}.mp3"
            cmd="ffmpeg -i \"$input_path\" -vn -acodec mp3 -ab 192k \"$BASE_DIR/$output_file\" -y"
            ;;
        *) echo -e "${RED}Pilihan tidak valid!${NC}"; return 1 ;;
    esac
    
    if [ -n "$cmd" ]; then
        exec_with_spinner "$cmd" "Mengkonversi ke ${output_file##*.}"
        if [ $? -eq 0 ]; then
            echo -e "${GREEN}✅ File: $BASE_DIR/$output_file${NC}"
            echo -e "${CYAN}Ukuran: $(du -h "$BASE_DIR/$output_file" | cut -f1)${NC}"
        fi
    fi
}

potong_video() {
    echo -e "\n${CYAN}[POTONG VIDEO (TRIM)]${NC}"
    read -p "File input: " input_file
    cek_file "$input_file" || return 1
    
    echo -e "${YELLOW}Contoh format waktu: 00:00:10 (10 detik) atau 00:01:30 (1 menit 30 detik)${NC}"
    read -p "Mulai dari (HH:MM:SS): " start_time
    read -p "Durasi (HH:MM:SS): " duration
    read -p "Nama output: " output_file
    
    exec_with_spinner "ffmpeg -i \"$BASE_DIR/$input_file\" -ss $start_time -t $duration -c copy \"$BASE_DIR/$output_file\" -y" "Memotong video"
    echo -e "${GREEN}✅ File: $BASE_DIR/$output_file${NC}"
}

resize_video() {
    echo -e "\n${CYAN}[RESIZE VIDEO]${NC}"
    read -p "File input: " input_file
    cek_file "$input_file" || return 1
    
    echo "Pilihan resolusi:"
    echo "  1. 1920x1080 (1080p)"
    echo "  2. 1280x720 (720p)"
    echo "  3. 854x480 (480p)"
    echo "  4. 640x360 (360p)"
    echo "  5. Custom"
    read -p "Pilih (1-5): " res_choice
    
    case $res_choice in
        1) resolution="1920x1080" ;;
        2) resolution="1280x720" ;;
        3) resolution="854x480" ;;
        4) resolution="640x360" ;;
        5) read -p "Masukkan resolusi (contoh: 1280x720): " resolution ;;
        *) echo -e "${RED}Pilihan tidak valid!${NC}" && return 1 ;;
    esac
    
    read -p "Nama output: " output_file
    exec_with_spinner "ffmpeg -i \"$BASE_DIR/$input_file\" -vf scale=$resolution -c:a copy \"$BASE_DIR/$output_file\" -y" "Meresize ke $resolution"
    echo -e "${GREEN}✅ File: $BASE_DIR/$output_file${NC}"
}

merge_video() {
    echo -e "\n${CYAN}[MERGE BANYAK VIDEO]${NC}"
    local video_files=()
    
    echo -e "${GREEN}[PILIH FILE VIDEO]${NC}"
    echo "  1. Pilih file satu per satu"
    echo "  2. Gabung semua video dalam folder"
    echo "  3. Pilih dari daftar file"
    read -p "Pilih (1-3): " input_method
    
    case $input_method in
        1)
            echo -e "\n${YELLOW}Masukkan nama file (ketik 'selesai' jika sudah)${NC}"
            while true; do
                read -p "➜ Video $(( ${#video_files[@]} + 1 )): " video_name
                [[ "$video_name" == "selesai" ]] && break
                [[ -z "$video_name" ]] && continue
                cek_file "$video_name" && video_files+=("$video_name")
            done
            ;;
        2)
            mapfile -t video_files < <(ls -1 "$BASE_DIR" | grep -E "\.(mp4|mkv|avi|mov)$" | sort)
            if [ ${#video_files[@]} -eq 0 ]; then
                echo -e "${RED}❌ Tidak ada file video!${NC}"
                return 1
            fi
            echo -e "${CYAN}Ditemukan ${#video_files[@]} file video${NC}"
            ;;
        3)
            local all_videos=()
            mapfile -t all_videos < <(ls -1 "$BASE_DIR" | grep -E "\.(mp4|mkv|avi|mov)$" | sort)
            echo -e "\n${CYAN}Daftar video:${NC}"
            for i in "${!all_videos[@]}"; do
                echo -e "  $((i+1)). ${all_videos[$i]}"
            done
            read -p "Masukkan nomor (pisah spasi/koma, contoh: 1 3 5): " selected_nums
            selected_nums=$(echo "$selected_nums" | tr ',' ' ')
            for num in $selected_nums; do
                idx=$((num-1))
                [ $idx -ge 0 ] && [ $idx -lt ${#all_videos[@]} ] && video_files+=("${all_videos[$idx]}")
            done
            ;;
    esac
    
    if [ ${#video_files[@]} -lt 2 ]; then
        echo -e "${RED}❌ Minimal 2 video untuk digabung!${NC}"
        return 1
    fi
    
    read -p "Nama output: " output_file
    [[ -z "$output_file" ]] && output_file="merged_$(date +%Y%m%d_%H%M%S).mp4"
    
    cd "$BASE_DIR" || return 1
    rm -f videos_list.txt
    for f in "${video_files[@]}"; do
        echo "file '$f'" >> videos_list.txt
    done
    
    exec_with_spinner "ffmpeg -f concat -safe 0 -i videos_list.txt -c copy \"$output_file\" -y" "Menggabungkan ${#video_files[@]} video"
    rm -f videos_list.txt
    cd "$HOME" || return 1
    
    echo -e "${GREEN}✅ Hasil: $BASE_DIR/$output_file${NC}"
}

loop_video() {
    local loop_count=$1
    local message=$2
    
    read -p "Nama file input: " vid
    cek_file "$vid" || return 1
    read -p "Nama file output: " out
    
    exec_with_spinner "ffmpeg -stream_loop $loop_count -i \"$BASE_DIR/$vid\" -c copy \"$BASE_DIR/$out\" -y" "$message"
}

# ============================================
# KOMPRESI
# ============================================

kompres_video() {
    echo -e "\n${CYAN}[KOMPRES VIDEO]${NC}"
    read -p "Input: " vid
    cek_file "$vid" || return 1
    read -p "Output: " out
    
    exec_with_spinner "ffmpeg -i \"$BASE_DIR/$vid\" -vcodec libx264 -crf 28 -acodec aac \"$BASE_DIR/$out\" -y" "Mengompres video"
    echo -e "${GREEN}✅ File: $BASE_DIR/$out${NC}"
}

batch_kompres_video() {
    echo -e "\n${CYAN}[BATCH KOMPRES VIDEO]${NC}"
    
    local video_files=()
    mapfile -t video_files < <(ls -1 "$BASE_DIR" | grep -E "\.(mp4|mkv|avi|mov)$" | sort)
    
    if [ ${#video_files[@]} -eq 0 ]; then
        echo -e "${RED}❌ Tidak ada file video!${NC}"
        return 1
    fi
    
    echo -e "${CYAN}Ditemukan ${#video_files[@]} file video:${NC}"
    for i in "${!video_files[@]}"; do
        local size=$(du -h "$BASE_DIR/${video_files[$i]}" | cut -f1)
        echo -e "  $((i+1)). ${video_files[$i]} ($size)"
    done
    
    echo -e "\n${GREEN}[SETTING KOMPRESI]${NC}"
    echo "  1. Ringan (CRF 23)"
    echo "  2. Sedang (CRF 28)"
    echo "  3. Berat (CRF 32)"
    read -p "Pilih (1-3): " preset_choice
    
    case $preset_choice in
        1) crf="23" ;;
        2) crf="28" ;;
        3) crf="32" ;;
        *) crf="28" ;;
    esac
    
    local output_dir="$BASE_DIR/compressed_$(date +%Y%m%d_%H%M%S)"
    mkdir -p "$output_dir"
    
    echo -e "\n${YELLOW}Mulai kompres ${#video_files[@]} file...${NC}"
    local total=${#video_files[@]}
    local completed=0
    
    for f in "${video_files[@]}"; do
        completed=$((completed + 1))
        local filename="${f%.*}"
        local output_file="$output_dir/${filename}_compressed.mp4"
        
        echo -e "\n${CYAN}[$completed/$total]${NC} $f"
        exec_with_spinner "ffmpeg -i \"$BASE_DIR/$f\" -c:v libx264 -crf $crf -preset fast -c:a aac -b:a 128k \"$output_file\" -y" "Kompres $f"
    done
    
    echo -e "\n${GREEN}✅ Batch kompres selesai!${NC}"
    echo -e "${CYAN}📁 Hasil di: $output_dir${NC}"
    
    read -p "Buka folder hasil? (y/n): " buka
    [[ "$buka" =~ ^[Yy]$ ]] && termux-open "$output_dir"
}

# ============================================
# GABUNG MP3 & VIDEO
# ============================================

gabung_mp3() {
    echo -e "\n${CYAN}[GABUNG MP3]${NC}"
    echo "Masukkan file audio (pisah spasi):"
    read -a audios
    read -p "Nama output: " out
    
    cd "$BASE_DIR" || exit
    rm -f list.txt
    for f in "${audios[@]}"; do
        [ -f "$f" ] && echo "file '$f'" >> list.txt
    done
    
    exec_with_spinner "ffmpeg -f concat -safe 0 -i list.txt -c copy \"$out\" -y" "Menggabungkan MP3"
    rm -f list.txt
    cd "$HOME" || exit
    echo -e "${GREEN}✅ Selesai!${NC}"
}

gabung_video_audio() {
    echo -e "\n${CYAN}[GABUNG VIDEO & AUDIO]${NC}"
    read -p "Video: " vid
    cek_file "$vid" || return 1
    read -p "Audio: " aud
    cek_file "$aud" || return 1
    read -p "Output: " out
    
    exec_with_spinner "ffmpeg -i \"$BASE_DIR/$vid\" -i \"$BASE_DIR/$aud\" -c:v libx264 -preset fast -crf 23 -c:a aac -shortest -map 0:v -map 1:a -y \"$BASE_DIR/$out\"" "Menggabungkan video & audio"
    echo -e "${GREEN}✅ File: $BASE_DIR/$out${NC}"
}

# ============================================
# PROSES BERANTAI
# ============================================

proses_berantai() {
    echo -e "\n${CYAN}════════════════════════════════════════${NC}"
    echo -e "${PURPLE}     PROSES BERANTAI OTOMATIS${NC}"
    echo -e "${CYAN}════════════════════════════════════════${NC}"
    echo -e "${YELLOW}Gabung MP3 → Gabung Video → Kompres${NC}\n"
    
    echo -e "${GREEN}[INPUT FILE MP3]${NC}"
    echo -e "Masukkan nama file MP3 (pisah spasi)"
    read -p "➜ File MP3: " -a audios
    
    echo ""
    echo -e "${GREEN}[INPUT FILE VIDEO]${NC}"
    read -p "➜ Video background: " video_file
    
    echo ""
    echo -e "${GREEN}[NAMA OUTPUT]${NC}"
    read -p "➜ File hasil: " final_output
    
    echo ""
    echo -e "${GREEN}[PILIH KOMPRESI]${NC}"
    echo "  1. Ringan | 2. Sedang | 3. Berat | 4. WhatsApp | 5. Tanpa"
    read -p "➜ Pilih (1-5): " compress_level
    
    echo -e "\n${BLUE}────────────────────────────────────────${NC}"
    echo -e "${YELLOW}📋 RINGKASAN:${NC}"
    for f in "${audios[@]}"; do echo "  • $f"; done
    echo -e "  • Video: $video_file"
    echo -e "  • Output: $final_output"
    echo -e "${BLUE}────────────────────────────────────────${NC}"
    
    read -p "Lanjutkan? (y/n): " konfirm
    [[ "$konfirm" != "y" ]] && return 1
    
    for f in "${audios[@]}"; do
        [ ! -f "$BASE_DIR/$f" ] && echo -e "${RED}❌ $f tidak ditemukan!${NC}" && return 1
    done
    [ ! -f "$BASE_DIR/$video_file" ] && echo -e "${RED}❌ Video tidak ditemukan!${NC}" && return 1
    
    cd "$BASE_DIR" || return 1
    
    # Step 1: Gabung MP3
    echo -e "\n${GREEN}[1/3] Gabung MP3${NC}"
    local merged_mp3="temp_mp3_$$.mp3"
    rm -f mp3_list.txt
    for f in "${audios[@]}"; do echo "file '$f'" >> mp3_list.txt; done
    ffmpeg -f concat -safe 0 -i mp3_list.txt -c copy "$merged_mp3" -y 2>&1 | tail -3
    rm -f mp3_list.txt
    
    # Step 2: Gabung dengan video
    echo -e "\n${GREEN}[2/3] Gabung dengan Video${NC}"
    local merged_video="temp_video_$$.mp4"
    local mp3_dur=$(ffprobe -v error -show_entries format=duration -of default=noprint_wrappers=1:nokey=1 "$merged_mp3" 2>/dev/null)
    local vid_dur=$(ffprobe -v error -show_entries format=duration -of default=noprint_wrappers=1:nokey=1 "$video_file" 2>/dev/null)
    mp3_dur=${mp3_dur%.*}
    vid_dur=${vid_dur%.*}
    
    if [ $vid_dur -lt $mp3_dur ]; then
        local loop_needed=$(( (mp3_dur + vid_dur - 1) / vid_dur ))
        echo -e "${YELLOW}⚠ Video di-loop ${loop_needed}x${NC}"
        exec_with_spinner "ffmpeg -stream_loop $loop_needed -i \"$video_file\" -i \"$merged_mp3\" -c:v libx264 -preset fast -crf 23 -c:a aac -b:a 192k -map 0:v -map 1:a -t $mp3_dur \"$merged_video\" -y" "Menggabungkan"
    else
        exec_with_spinner "ffmpeg -i \"$video_file\" -i \"$merged_mp3\" -c:v libx264 -preset fast -crf 23 -c:a aac -b:a 192k -map 0:v -map 1:a -t $mp3_dur \"$merged_video\" -y" "Menggabungkan"
    fi
    
    # Step 3: Kompresi
    echo -e "\n${GREEN}[3/3] Kompresi${NC}"
    case $compress_level in
        1) exec_with_spinner "ffmpeg -i \"$merged_video\" -c:v libx264 -crf 23 -preset medium -c:a aac -b:a 128k \"$final_output\" -y" "Kompres ringan" ;;
        2) exec_with_spinner "ffmpeg -i \"$merged_video\" -c:v libx264 -crf 28 -preset fast -c:a aac -b:a 96k \"$final_output\" -y" "Kompres sedang" ;;
        3) exec_with_spinner "ffmpeg -i \"$merged_video\" -c:v libx264 -crf 32 -preset veryfast -vf scale=854:-2 -c:a aac -b:a 64k \"$final_output\" -y" "Kompres berat" ;;
        4) exec_with_spinner "ffmpeg -i \"$merged_video\" -c:v libx264 -crf 28 -preset fast -vf scale=1280:-2 -c:a aac -b:a 96k -fs 16M \"$final_output\" -y" "Kompres WhatsApp" ;;
        5) cp "$merged_video" "$final_output"; echo -e "${GREEN}✓ Tanpa kompresi${NC}" ;;
        *) exec_with_spinner "ffmpeg -i \"$merged_video\" -c:v libx264 -crf 28 -preset fast -c:a aac -b:a 96k \"$final_output\" -y" "Kompres sedang" ;;
    esac
    
    if [ -f "$final_output" ]; then
        echo -e "\n${GREEN}════════════════════════════════════════${NC}"
        echo -e "${GREEN}✅ PROSES BERANTAI SELESAI!${NC}"
        echo -e "${GREEN}════════════════════════════════════════${NC}"
        echo -e "${CYAN}📁 File hasil: $BASE_DIR/$final_output${NC}"
        echo -e "${CYAN}📊 Ukuran: $(du -h "$final_output" | cut -f1)${NC}"
        rm -f "$merged_mp3" "$merged_video"
    fi
    
    cd "$HOME" || return 1
}

