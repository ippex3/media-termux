#!/bin/bash

# ============================================
# JAMIL-YT v2.0 - Media Downloader & Converter
# ============================================

# Konfigurasi
BASE_DIR="/storage/emulated/0/JAMIL-YT"
PY_SCRIPT="$PREFIX/bin/jamil_downloader.py"
LOG_FILE="$BASE_DIR/jamil_log.txt"
VERSION="2.0"

# Buat folder jika belum ada
mkdir -p "$BASE_DIR"
touch "$LOG_FILE"

# Warna untuk tampilan
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# Fungsi header
tampilkan_header() {
    clear
    echo -e "${CYAN}========================================${NC}"
    echo -e "${PURPLE}       JAMIL-YT v$VERSION              ${NC}"
    echo -e "${CYAN}========================================${NC}"
    echo -e "${GREEN}   Media Downloader & Converter Tool    ${NC}"
    echo -e "${CYAN}========================================${NC}\n"
}

# Progress bar yang lebih baik
progress_bar() {
    local duration=$1
    local current=$2
    local width=50
    local percent=$(( current * 100 / duration ))
    local filled=$(( width * current / duration ))
    local empty=$(( width - filled ))
    
    printf "\r${YELLOW}["
    printf "%${filled}s" | tr ' ' '█'
    printf "%${empty}s" | tr ' ' '░'
    printf "] ${GREEN}%3d%%${NC}" "$percent"
}

# Simulasi progress dengan spinner untuk proses yang lama
tampilkan_progress() {
    local pid=$1
    local message=$2
    local spin='⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏'
    local i=0
    
    while kill -0 "$pid" 2>/dev/null; do
        printf "\r${CYAN}%s${NC} ${YELLOW}%c${NC}" "$message" "${spin:i++%10:1}"
        sleep 0.1
    done
    wait "$pid" 2>/dev/null
    local exit_code=$?
    if [ $exit_code -eq 0 ]; then
        printf "\r${GREEN}✓ %s Selesai!    ${NC}\n" "$message"
    else
        printf "\r${RED}✗ %s Gagal!    ${NC}\n" "$message"
    fi
    return $exit_code
}

# Download dengan progress
download_with_progress() {
    local mode=$1
    local url=$2
    
    echo -e "${BLUE}[*] Memulai download...${NC}"
    
    # Gunakan yt-dlp dengan progress
    if [ "$mode" = "yt_video" ]; then
        yt-dlp -f "bestvideo[ext=mp4]+bestaudio[ext=m4a]/best[ext=mp4]/best" \
               -o "$BASE_DIR/%(title)s.%(ext)s" \
               --progress \
               "$url" 2>&1 | while IFS= read -r line; do
            if [[ $line =~ ([0-9]+)% ]]; then
                percent=${BASH_REMATCH[1]}
                progress_bar 100 "$percent"
            fi
        done
        echo -e "\n${GREEN}✓ Download selesai!${NC}"
    elif [ "$mode" = "yt_audio" ]; then
        yt-dlp -f bestaudio \
               --extract-audio \
               --audio-format mp3 \
               --audio-quality 0 \
               -o "$BASE_DIR/%(title)s.%(ext)s" \
               --progress \
               "$url" 2>&1 | while IFS= read -r line; do
            if [[ $line =~ ([0-9]+)% ]]; then
                percent=${BASH_REMATCH[1]}
                progress_bar 100 "$percent"
            fi
        done
        echo -e "\n${GREEN}✓ Download selesai!${NC}"
    elif [ "$mode" = "ig" ]; then
        yt-dlp -f best \
               -o "$BASE_DIR/instagram_%(id)s.%(ext)s" \
               "$url"
        echo -e "${GREEN}✓ Download Instagram selesai!${NC}"
    fi
}

# Pastikan file python downloader tersedia (fallback)
if [ ! -f "$PY_SCRIPT" ]; then
    echo -e "${YELLOW}[*] Mengunduh komponen downloader...${NC}"
    curl -# -L https://raw.githubusercontent.com/ippex3/media-termux/main/downloader.py -o "$PY_SCRIPT"
    chmod +x "$PY_SCRIPT"
fi

# Fungsi untuk menahan layar
kembali_ke_menu() {
    echo -e "\n${CYAN}----------------------------------------${NC}"
    read -p "Tekan [Enter] untuk kembali ke menu utama..."
}

# Fungsi konfirmasi sebelum eksekusi
konfirmasi_menu() {
    echo -e "\n${YELLOW}[Tekan 'n' lalu Enter jika ingin batal]${NC}"
    read -p "Apakah ingin melanjutkan? (y/n): " konfirm
    [[ "$konfirm" =~ ^[Nn]$ ]] && return 1 || return 0
}

# Cek apakah file ada sebelum diproses
cek_file() {
    local file=$1
    if [ ! -f "$BASE_DIR/$file" ]; then
        echo -e "${RED}❌ File '$file' tidak ditemukan di $BASE_DIR${NC}"
        return 1
    fi
    return 0
}

# Fungsi konversi format
konversi_format() {
    echo -e "\n${CYAN}[KONVERSI FORMAT VIDEO]${NC}"
    echo "Format yang tersedia:"
    echo "  1. MP4 (H.264)"
    echo "  2. AVI"
    echo "  3. MKV"
    echo "  4. MOV"
    echo "  5. WEBM"
    echo "  6. GIF (dari video)"
    echo "  7. MP4 (kualitas rendah - ukuran kecil)"
    echo "  8. MP4 (kualitas tinggi)"
    echo "  9. Extract Frame (JPG per detik)"
    echo "  10. Convert Audio ke MP3"
    
    read -p "Pilih format target (1-10): " format_choice
    read -p "Nama file input: " input_file
    
    cek_file "$input_file" || return 1
    
    local input_path="$BASE_DIR/$input_file"
    local filename="${input_file%.*}"
    local output_file=""
    
    case $format_choice in
        1)
            output_file="${filename}_converted.mp4"
            echo -e "${BLUE}[*] Mengkonversi ke MP4...${NC}"
            ffmpeg -i "$input_path" -c:v libx264 -preset medium -crf 23 -c:a aac -b:a 128k "$BASE_DIR/$output_file" -y 2>&1 | tee -a "$LOG_FILE"
            ;;
        2)
            output_file="${filename}.avi"
            echo -e "${BLUE}[*] Mengkonversi ke AVI...${NC}"
            ffmpeg -i "$input_path" -c:v libx264 -c:a mp3 "$BASE_DIR/$output_file" -y 2>&1 | tee -a "$LOG_FILE"
            ;;
        3)
            output_file="${filename}.mkv"
            echo -e "${BLUE}[*] Mengkonversi ke MKV...${NC}"
            ffmpeg -i "$input_path" -c copy "$BASE_DIR/$output_file" -y 2>&1 | tee -a "$LOG_FILE"
            ;;
        4)
            output_file="${filename}.mov"
            echo -e "${BLUE}[*] Mengkonversi ke MOV...${NC}"
            ffmpeg -i "$input_path" -c:v libx264 -c:a aac "$BASE_DIR/$output_file" -y 2>&1 | tee -a "$LOG_FILE"
            ;;
        5)
            output_file="${filename}.webm"
            echo -e "${BLUE}[*] Mengkonversi ke WEBM...${NC}"
            ffmpeg -i "$input_path" -c:v libvpx -c:a libvorbis "$BASE_DIR/$output_file" -y 2>&1 | tee -a "$LOG_FILE"
            ;;
        6)
            output_file="${filename}.gif"
            echo -e "${BLUE}[*] Membuat GIF (10 detik pertama)...${NC}"
            ffmpeg -i "$input_path" -t 10 -vf "fps=10,scale=320:-1:flags=lanczos" -c:v gif "$BASE_DIR/$output_file" -y 2>&1 | tee -a "$LOG_FILE"
            ;;
        7)
            output_file="${filename}_small.mp4"
            echo -e "${BLUE}[*] Mengkompres ke ukuran kecil...${NC}"
            ffmpeg -i "$input_path" -c:v libx264 -crf 28 -preset fast -c:a aac -b:a 64k -vf "scale=854:-2" "$BASE_DIR/$output_file" -y 2>&1 | tee -a "$LOG_FILE"
            ;;
        8)
            output_file="${filename}_high.mp4"
            echo -e "${BLUE}[*] Konversi kualitas tinggi...${NC}"
            ffmpeg -i "$input_path" -c:v libx264 -preset slow -crf 18 -c:a aac -b:a 320k "$BASE_DIR/$output_file" -y 2>&1 | tee -a "$LOG_FILE"
            ;;
        9)
            output_dir="$BASE_DIR/frames_${filename}"
            mkdir -p "$output_dir"
            echo -e "${BLUE}[*] Ekstrak frame (1 frame per detik)...${NC}"
            ffmpeg -i "$input_path" -vf "fps=1" "$output_dir/frame_%04d.jpg" -y 2>&1 | tee -a "$LOG_FILE"
            echo -e "${GREEN}✓ Frame tersimpan di: $output_dir${NC}"
            return 0
            ;;
        10)
            output_file="${filename}.mp3"
            echo -e "${BLUE}[*] Ekstrak audio ke MP3...${NC}"
            ffmpeg -i "$input_path" -vn -acodec mp3 -ab 192k "$BASE_DIR/$output_file" -y 2>&1 | tee -a "$LOG_FILE"
            ;;
        *)
            echo -e "${RED}Pilihan tidak valid!${NC}"
            return 1
            ;;
    esac
    
    if [ $? -eq 0 ] && [ -n "$output_file" ]; then
        echo -e "${GREEN}✅ Konversi selesai! File: $BASE_DIR/$output_file${NC}"
        echo -e "${CYAN}Ukuran file: $(du -h "$BASE_DIR/$output_file" | cut -f1)${NC}"
    else
        echo -e "${RED}❌ Konversi gagal!${NC}"
    fi
}

# Fungsi batch download dari file
batch_download() {
    local mode=$1
    local url_file="$BASE_DIR/daftar_url.txt"
    
    echo -e "\n${CYAN}[BATCH DOWNLOAD MODE]${NC}"
    echo -e "Buat file daftar URL di: ${YELLOW}$url_file${NC}"
    echo "Format: satu URL per baris"
    echo ""
    
    if [ ! -f "$url_file" ]; then
        read -p "File daftar_url.txt belum ada. Buat sekarang? (y/n): " buat
        if [[ "$buat" =~ ^[Yy]$ ]]; then
            nano "$url_file"
        else
            echo -e "${RED}Batch download dibatalkan.${NC}"
            return 1
        fi
    fi
    
    if [ -f "$url_file" ]; then
        local total=$(grep -c -v "^$" "$url_file")
        echo -e "\n${GREEN}[*] Memulai batch download ($total URL ditemukan)${NC}"
        local counter=1
        
        while IFS= read -r url; do
            [[ -z "$url" ]] && continue
            echo -e "\n${CYAN}[$counter/$total] Mengunduh:${NC} $url"
            
            if [ "$mode" = "video" ]; then
                yt-dlp -f "best[ext=mp4]" -o "$BASE_DIR/%(title)s.%(ext)s" "$url"
            else
                yt-dlp -f bestaudio --extract-audio --audio-format mp3 -o "$BASE_DIR/%(title)s.%(ext)s" "$url"
            fi
            
            echo -e "${GREEN}✓ Selesai download ke-$counter${NC}"
            ((counter++))
        done < "$url_file"
        
        echo -e "\n${GREEN}✅ Batch download selesai!${NC}"
        echo -e "Log disimpan di: ${YELLOW}$LOG_FILE${NC}"
    else
        echo -e "${RED}❌ File daftar_url.txt tidak ditemukan!${NC}"
        return 1
    fi
}

# Loop video dengan progress
loop_video() {
    local loop_count=$1
    local message=$2
    
    read -p "Nama file input: " vid
    cek_file "$vid" || return 1
    read -p "Nama file output: " out
    
    echo -e "${BLUE}[*] $message${NC}"
    ffmpeg -stream_loop "$loop_count" -i "$BASE_DIR/$vid" -c copy "$BASE_DIR/$out" -y 2>&1 | \
    while IFS= read -r line; do
        if [[ $line =~ frame=.* ]]; then
            echo -ne "\r${YELLOW}Processing...${NC} $line"
        fi
    done
    
    echo -e "\n${GREEN}✅ File tersimpan: $BASE_DIR/$out${NC}"
}

# Menu utama
while true; do
    tampilkan_header
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo -e "${PURPLE} [DOWNLOADER MENU]${NC}"
    echo "  1. Download Video (YT, TikTok, FB, X)"
    echo "  2. Download Audio/MP3"
    echo "  3. Download Video Instagram"
    echo "  4. Batch Download (Mode Video)"
    echo "  5. Batch Download (Mode Audio)"
    echo ""
    echo -e "${PURPLE} [KONVERSI & EDITING]${NC}"
    echo "  6. Konversi Format Video/Audio"
    echo "  7. Loop Video: 1 Jam"
    echo "  8. Loop Video: Custom Jumlah"
    echo "  9. Gabung Video & Audio"
    echo " 10. Gabung MP3 Saja"
    echo " 11. Kompres Video"
    echo ""
    echo -e "${PURPLE} [UTILITY]${NC}"
    echo " 12. Lihat Daftar File"
    echo " 13. Info File Media"
    echo " 14. Hapus File"
    echo ""
    echo -e "${RED} [KELUAR]${NC}"
    echo " 15. Keluar dari Aplikasi"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    read -p "Pilih opsi (1-15): " opsi

    case $opsi in
        1) 
            echo -e "\n${GREEN}[Download Video]${NC}" 
            if konfirmasi_menu; then 
                read -p "URL: " url
                download_with_progress "yt_video" "$url"
                kembali_ke_menu
            fi 
            ;;
        2) 
            echo -e "\n${GREEN}[Download Audio]${NC}" 
            if konfirmasi_menu; then 
                read -p "URL: " url
                download_with_progress "yt_audio" "$url"
                kembali_ke_menu
            fi 
            ;;
        3) 
            echo -e "\n${GREEN}[Download Instagram]${NC}" 
            if konfirmasi_menu; then 
                read -p "URL: " url
                download_with_progress "ig" "$url"
                kembali_ke_menu
            fi 
            ;;
        4)  
            echo -e "\n${GREEN}[Batch Download Video]${NC}" 
            if konfirmasi_menu; then 
                batch_download "video"
                kembali_ke_menu
            fi 
            ;;
        5)  
            echo -e "\n${GREEN}[Batch Download Audio]${NC}" 
            if konfirmasi_menu; then 
                batch_download "audio"
                kembali_ke_menu
            fi 
            ;;
        6)
            konversi_format
            kembali_ke_menu
            ;;
        7)
            echo -e "\n${GREEN}[Loop Video 1 Jam]${NC}"
            if konfirmasi_menu; then
                loop_video 327 "Memproses loop video 1 jam..."
                kembali_ke_menu
            fi
            ;;
        8)
            echo -e "\n${GREEN}[Loop Custom]${NC}"
            if konfirmasi_menu; then
                read -p "Jumlah repetisi: " n
                loop_video "$n" "Memproses loop $n kali..."
                kembali_ke_menu
            fi
            ;;
        9)
            echo -e "\n${GREEN}[Gabung Video & Audio]${NC}"
            if konfirmasi_menu; then
                read -p "Nama file video: " vid
                cek_file "$vid" || { kembali_ke_menu; continue; }
                read -p "Nama file audio: " aud
                cek_file "$aud" || { kembali_ke_menu; continue; }
                read -p "Nama file output: " out
                echo -e "${BLUE}[*] Menggabungkan...${NC}"
                ffmpeg -i "$BASE_DIR/$vid" -i "$BASE_DIR/$aud" \
                    -c:v libx264 -preset fast -crf 23 \
                    -c:a aac -shortest -map 0:v -map 1:a \
                    -y "$BASE_DIR/$out" 2>&1 | tee -a "$LOG_FILE"
                echo -e "${GREEN}✅ File tersimpan: $BASE_DIR/$out${NC}"
                kembali_ke_menu
            fi
            ;;
        10)
            echo -e "\n${GREEN}[Gabung MP3]${NC}"
            if konfirmasi_menu; then
                echo "Masukkan file audio (pisah spasi):" 
                read -a audios
                read -p "Nama output: " out
                cd "$BASE_DIR" || exit
                > list.txt
                for f in "${audios[@]}"; do
                    if [ -f "$f" ]; then
                        echo "file '$f'" >> list.txt
                    else
                        echo -e "${RED}File $f tidak ditemukan!${NC}"
                    fi
                done
                ffmpeg -f concat -safe 0 -i list.txt -c copy "$out" -y 2>&1 | tee -a "$LOG_FILE"
                rm list.txt
                cd "$HOME" || exit
                echo -e "${GREEN}✅ Selesai!${NC}"
                kembali_ke_menu
            fi
            ;;
        11)
            echo -e "\n${GREEN}[Kompres Video]${NC}"
            if konfirmasi_menu; then
                read -p "Input: " vid
                cek_file "$vid" || { kembali_ke_menu; continue; }
                read -p "Output: " out
                echo -e "${BLUE}[*] Mengompres...${NC}"
                ffmpeg -i "$BASE_DIR/$vid" -vcodec libx264 -crf 28 -acodec aac "$BASE_DIR/$out" -y 2>&1 | tee -a "$LOG_FILE"
                echo -e "${GREEN}✅ File tersimpan: $BASE_DIR/$out${NC}"
                kembali_ke_menu
            fi
            ;;
        12)
            echo -e "\n${CYAN}[DAFTAR FILE]${NC}"
            echo "========================================"
            ls -lah "$BASE_DIR" | grep -E "\.(mp4|mp3|mkv|webm|m4a|avi|mov|gif|jpg|png)$" || echo "Tidak ada file media"
            echo "========================================"
            kembali_ke_menu
            ;;
        13)
            echo -e "\n${CYAN}[INFO FILE]${NC}"
            read -p "Nama file: " file_info
            if [ -f "$BASE_DIR/$file_info" ]; then
                ffmpeg -i "$BASE_DIR/$file_info" 2>&1 | grep -E "Duration|Video|Audio"
            else
                echo -e "${RED}File tidak ditemukan!${NC}"
            fi
            kembali_ke_menu
            ;;
        14)
            echo -e "\n${RED}[HAPUS FILE]${NC}"
            read -p "Nama file: " file_del
            if [ -f "$BASE_DIR/$file_del" ]; then
                rm -i "$BASE_DIR/$file_del"
            else
                echo -e "${RED}File tidak ditemukan!${NC}"
            fi
            kembali_ke_menu
            ;;
        15) 
            echo -e "\n${GREEN}Terima kasih telah menggunakan JAMIL-YT v$VERSION!${NC}\n"
            echo -e "Total log disimpan di: ${YELLOW}$LOG_FILE${NC}"
            echo -e "Folder penyimpanan: ${YELLOW}$BASE_DIR${NC}\n"
            exit 0
            ;;
        *) 
            echo -e "\n${RED}[!] Opsi tidak valid!${NC}" 
            kembali_ke_menu 
            ;;
    esac
done